# Zig build output, cache, and fetched dependencies (deps come from build.zig.zon)
zig-out/
.zig-cache/
zig-cache/
zig-pkg/

# Python
__pycache__/
*.py[cod]

# Runtime: per-run swarm dirs (work, sqlite memory, event streams)
data/

# Example run outputs — the embedded harnesses write forensics here per run.
examples/embedded/debug/

# Secrets — never commit. Keys live here or in the environment.
keys.env
*.key
.env
.env.*
!.env.example

# The neuron memory-engine binary is a build artifact / release asset, not source.
# deploy.py fetches + builds it on first run (or place it at bin/neuron[.exe] yourself).
bin/*
!bin/.gitkeep

# neuron-db source + target that deploy.py downloads and compiles on first run
.neuron-src/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
