# Zig build output, cache, and fetched dependencies (deps come from build.zig.zon)
zig-out/
.zig-cache/
zig-cache/
zig-pkg/

# toolchains the installer / build scripts bootstrap into the tree (lib-deps.sh)
.zig/
.zig-dl/
.neuron-src/
rustup-init.exe

# Python bytecode (the example fixtures under examples/ are still Python)
__pycache__/
*.py[cod]

# Runtime: per-run swarm dirs (work, sqlite memory, event streams)
data/

# Runtime neuron-db files a local dev run drops at the repo root
neurons.db
neurons.db-*

# Fleet-console roster/audit snapshot — runtime state, not source
hub_state.json
hub_state.json.tmp

# Example run outputs — the embedded harnesses write forensics here per run.
examples/embedded/debug/
examples/**/data/

# Secrets — never commit. Keys live here or in the environment.
keys.env
*.key
.env
.env.*
!.env.example

# The neuron memory-engine binary is a build artifact / release asset, not source.
# Place it at bin/neuron[.exe] (ships prebuilt in the release bundle).
bin/*
!bin/.gitkeep

# neuron-db source + target compiled from the sibling repo when building the engine
.neuron-src/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
SWARM_VCS_BLUEPRINT.md

# raylib F12 default screenshots (veil-desk uses F12 for the log overlay)
screenshot*.png

# release bundles produced by scripts/build-release.* (build output, not source)
dist/

# stray local agent/editor dirs
.codex/
